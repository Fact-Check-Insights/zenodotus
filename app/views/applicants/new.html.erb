<% @title_tag = t("request_access.request_access") %>

<div class="content">
	<%= form_with(
			model: @applicant,
			url: applicants_path,
			class: "form"
		) do |f| %>
		<fieldset class="fieldset">
			<div class="fieldset__header">
				<div class="fieldset__title h2">
					<%= t("request_access.request_access") %>
				</div>
				<div class="fieldset__description">
					<p class="b2"><%= t("request_access.access_to_the_site") %> <%= link_to t("request_access.please_get_in_touch"), contact_path %></p>
				</div>
			</div>
			<div class="fieldset__fields">
					<div class="field__wrapper--input">
						<%= f.label(
							:name,
							t("request_access.your_name")) %>
						<%= f.text_field(
							:name,
							required: true) %>
						<%= errors_for_field(
							@applicant,
							:name) %>
					</div>
					<div class="field__wrapper--input">
						<%= f.label(
							:email,
							t("request_access.email_address")) %>
						<%= f.email_field(
							:email,
							required: true,
							autocapitalize: "off",
							autocomplete: "email") %>
						<%= errors_for_field(
							@applicant,
							:email) %>
						<div class="field__description"><%= t("request_access.youll_need_to_confirm") %></div>
					</div>
					<div class="field__wrapper--input">
						<%= f.label :affiliation do %>
							<%= t("request_access.organization_affiliation") %> <span style="font-weight:normal"><%= t("request_access.if_any") %></span>
						<% end %>
						<%= f.text_field :affiliation %>
						<div class="field__description"><%= t("request_access.if_you_will_be_using") %></div>
					</div>
					<div class="field__wrapper--input">
						<%= f.label(
							:organization_type,
							t("request_access.type_of_organisation")) %>
						<%= f.select(
							:organization_type,
							options_for_select(Applicant::ORGANIZATION_TYPES, @applicant.organization_type),
							{ include_blank: true },
							{ required: true }) %>
						<%= errors_for_field(
							@applicant,
							:organization_type) %>
					</div>
					<div class="field__wrapper--input" id="organization-type-other-wrapper" style="display:none;">
						<%= f.label(
							:organization_type_other,
							t("request_access.if_other_please_specify")) %>
						<%= f.text_field(:organization_type_other) %>
						<%= errors_for_field(
							@applicant,
							:organization_type_other) %>
					</div>
					<div class="field__wrapper--input">
						<%= f.label(
							:primary_role,
							t("request_access.what_is_your_primary_role")) %>
						<%= f.select(
							:primary_role,
							options_for_select(Applicant::PRIMARY_ROLES, @applicant.primary_role),
							{ include_blank: true }) %>
						<%= errors_for_field(
							@applicant,
							:primary_role) %>
					</div>
					<div class="field__wrapper--input" id="primary-role-other-wrapper" style="display:none;">
						<%= f.label(
							:primary_role_other,
							t("request_access.if_other_please_specify")) %>
						<%= f.text_field(:primary_role_other) %>
						<%= errors_for_field(
							@applicant,
							:primary_role_other) %>
					</div>
					<div class="field__wrapper--input">
						<%= f.label(
							:country,
							t("request_access.where_are_you_located")) %>
						<%= f.country_select(
							:country,
							include_blank: true) %>
						<%= errors_for_field(
							@applicant,
							:country) %>
					</div>
					<div class="field__wrapper--input">
						<%= f.label(
							:use_case,
							t("request_access.how_do_you_plan_to_use_the_data")) %>
						<%= f.text_area(
							:use_case,
							size: "50x3",
							required: true) %>
						<%= errors_for_field(
							@applicant,
							:use_case) %>
					</div>
					<div class="field__wrapper--input">
						<fieldset>
							<legend><%= t("request_access.commercial_use_question") %></legend>
							<div style="display:flex; gap:1.5rem;">
								<div>
									<%= f.radio_button(:commercial_use, "true", required: true) %>
									<%= f.label(:commercial_use_true, t("request_access.yes")) %>
								</div>
								<div>
									<%= f.radio_button(:commercial_use, "false", required: true) %>
									<%= f.label(:commercial_use_false, t("request_access.no")) %>
								</div>
							</div>
						</fieldset>
						<%= errors_for_field(
							@applicant,
							:commercial_use) %>
					</div>
					<div class="field__wrapper--checkboxes">
						<div class="checkbox">
							<%= f.check_box(
								:accepted_terms,
								required: true ) %>
							<%= f.label :accepted_terms do %>
								<%= t("request_access.accept_the") %> <%= link_to t("request_access.terms_and_conditions"), terms_path, target: :_blank %>
								<%= errors_for_field(
									@applicant,
									:accepted_terms,
									full: false) %>
							<% end %>
						</div>
					</div>
			</div>
		</fieldset>
		<%= hidden_field_tag "g-recaptcha-response", nil, id: "g-recaptcha-response" %>
		<div class="form__align-with-fields">
			<%= submit_tag(
				t("request_access.submit_request"),
				class: "btn btn--submit",
				id: "apply-submit-btn"
			) %>
		</div>
		<script>
			(function() {
				function setupConditionalField(selectId, wrapperId, required) {
					var select = document.getElementById(selectId);
					var wrapper = document.getElementById(wrapperId);
					if (!select || !wrapper) return;
					var input = wrapper.querySelector("input");
					function toggle() {
						var isOther = select.value === "Other";
						wrapper.style.display = isOther ? "" : "none";
						if (input && required) input.required = isOther;
					}
					select.addEventListener("change", toggle);
					toggle();
				}
				setupConditionalField("applicant_organization_type", "organization-type-other-wrapper", true);
				setupConditionalField("applicant_primary_role", "primary-role-other-wrapper", false);
			})();

			(function() {
				var siteKey = "<%= Figaro.env.RECAPTCHA_SITE_KEY %>";
				var scriptUrl = "https://www.google.com/recaptcha/enterprise.js?render=" + siteKey;

				function bindSubmit() {
					var btn = document.getElementById("apply-submit-btn");
					if (!btn || btn.dataset.recaptchaBound) return;
					btn.dataset.recaptchaBound = "true";
					btn.addEventListener("click", function(e) {
						e.preventDefault();
						grecaptcha.enterprise.ready(function() {
							grecaptcha.enterprise.execute(siteKey, { action: "apply" }).then(function(token) {
								document.getElementById("g-recaptcha-response").value = token;
								btn.closest("form").submit();
							});
						});
					});
				}

				if (typeof grecaptcha !== "undefined" && grecaptcha.enterprise) {
					bindSubmit();
				} else {
					var script = document.createElement("script");
					script.src = scriptUrl;
					script.onload = bindSubmit;
					document.head.appendChild(script);
				}
			})();
		</script>
	<% end %>
</div>
